{
  "name": "vai-bi",
  "private": true,
  "version": "0.1.0",
  "engines": {
    "node": "24.x"
  },
  "workspaces": [
    "apps/web",
    "apps/api"
  ],
  "scripts": {
    "start": "npm run start:api",
    "dev:web": "npm run dev --workspace @vai-bi/web",
    "dev:api": "npm run dev --workspace @vai-bi/api",
